# Sthrip Configuration
# Copy to .env and fill in your values
# Generate secrets: openssl rand -hex 32

# === REQUIRED ===

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/sthrip

# Redis (for rate limiting, caching)
REDIS_URL=redis://localhost:6379/0

# Admin API key (generate: openssl rand -hex 32)
ADMIN_API_KEY=

# Environment: dev | staging | stagenet | production
ENVIRONMENT=dev

# === Monero Wallet RPC ===

# Hub mode: onchain (real Monero) | ledger (auto-credit, no node needed)
HUB_MODE=ledger

MONERO_RPC_HOST=127.0.0.1
MONERO_RPC_PORT=18082
MONERO_RPC_USER=
MONERO_RPC_PASS=

# HMAC secret for API key hashing — REQUIRED in production
# Generate: openssl rand -hex 32
API_KEY_HMAC_SECRET=

# Fernet key for encrypting webhook secrets — REQUIRED in production
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WEBHOOK_ENCRYPTION_KEY=

# Monero network: mainnet | stagenet | testnet
MONERO_NETWORK=stagenet

# === Deployment ===

# Log format: text | json
LOG_FORMAT=text

# Trusted proxy hosts (comma-separated, default: 127.0.0.1)
# TRUSTED_PROXY_HOSTS=*

# Web workers (default: 2, safe with worker guard for background tasks)
# Background tasks (DepositMonitor, escrow, SLA) run on primary worker only.
WEB_CONCURRENCY=2

# === OPTIONAL ===

# CORS origins (comma-separated, default: empty — no CORS)
# CORS_ORIGINS=https://app.sthrip.io,https://dashboard.sthrip.io

# Fee configuration (defaults shown)
# HUB_FEE_PERCENT=1.0
# MIN_FEE_XMR=0.0001

# Sentry DSN for error tracking
# SENTRY_DSN=

# Alert webhook URL for monitoring notifications (Telegram, Slack, or Discord)
# Telegram: https://api.telegram.org/bot<TOKEN>/sendMessage?chat_id=<CHAT_ID>
# Slack: https://hooks.slack.com/services/T.../B.../...
# Discord: https://discord.com/api/webhooks/...
# ALERT_WEBHOOK_URL=

# Your wallet address for testing
# TEST_WALLET_ADDRESS=
