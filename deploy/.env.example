# ═══════════════════════════════════════════════════════════════════════════════
# Sthrip Production Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
POSTGRES_USER=sthrip
# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=
POSTGRES_DB=sthrip

# Full URL (alternative to individual vars above)
# DATABASE_URL=postgresql://sthrip:password@postgres:5432/sthrip

# ═══════════════════════════════════════════════════════════════════════════════
# REDIS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# Generate with: openssl rand -hex 32
REDIS_PASSWORD=

# Full URL
# REDIS_URL=redis://:password@redis:6379/0

# ═══════════════════════════════════════════════════════════════════════════════
# MONERO WALLET RPC CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# Option 1: External Monero node
MONERO_RPC_HOST=your-monero-node-ip
MONERO_RPC_PORT=18082
MONERO_RPC_USER=rpc_username
MONERO_RPC_PASS=  # REQUIRED: Generate with `openssl rand -hex 32`

# Option 2: Self-hosted (uncomment in docker-compose.yml)
# MONERO_WALLET_PASSWORD=wallet_password

# ═══════════════════════════════════════════════════════════════════════════════
# API SECURITY
# ═══════════════════════════════════════════════════════════════════════════════
# Admin API key for management endpoints
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# DOMAIN & SSL
# ═══════════════════════════════════════════════════════════════════════════════
DOMAIN=api.sthrip.io
CORS_ORIGINS=https://app.sthrip.io,https://admin.sthrip.io

# SSL Certificate paths (inside nginx container)
# Place your SSL certificates in deploy/nginx/ssl/
SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem

# ═══════════════════════════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════
PORT=8000
LOG_LEVEL=INFO

# Rate limiting (requests per minute)
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_PREMIUM=1000

# ═══════════════════════════════════════════════════════════════════════════════
# MONITORING & ALERTING (Optional)
# ═══════════════════════════════════════════════════════════════════════════════
# Sentry DSN for error tracking
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Prometheus metrics endpoint
# METRICS_ENABLED=true
# METRICS_PORT=9090

# Alert webhook (Slack/Discord)
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# ═══════════════════════════════════════════════════════════════════════════════
# BACKUP CONFIGURATION (Optional)
# ═══════════════════════════════════════════════════════════════════════════════
# AWS S3 for backups
# AWS_ACCESS_KEY_ID=xxx
# AWS_SECRET_ACCESS_KEY=xxx
# AWS_BUCKET=sthrip-backups
# AWS_REGION=us-east-1

# Backup schedule (cron expression)
# BACKUP_SCHEDULE=0 2 * * *

# ═══════════════════════════════════════════════════════════════════════════════
# BLOCKCHAIN INDEXER (Optional)
# ═══════════════════════════════════════════════════════════════════════════════
# For tracking on-chain transactions
# INDEXER_ENABLED=false
# INDEXER_START_BLOCK=0
