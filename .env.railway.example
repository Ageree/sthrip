# Railway automatically provides these from plugins:
# DATABASE_URL - from Railway PostgreSQL plugin
# REDIS_URL - from Railway Redis plugin

# Required: Generate with: openssl rand -hex 32
ADMIN_API_KEY=
# Optional: Monero RPC (not needed for hub-only mode on stagenet)
# MONERO_RPC_HOST=127.0.0.1
# MONERO_RPC_PORT=18082

# Environment
ENVIRONMENT=stagenet
LOG_LEVEL=INFO

# CORS: comma-separated origins (empty = reject all cross-origin)
# Example: https://app.sthrip.io,https://admin.sthrip.io
CORS_ORIGINS=

# In dev mode (ENVIRONMENT=dev) localhost:3000/8000 are auto-added to CORS
# only when this is explicitly enabled. Misset ENVIRONMENT=dev should not
# silently widen origins on a non-dev box.
# CORS_DEV_AUTOEXTEND=

# Trusted proxy IPs whose X-Forwarded-For header is honoured. On Railway
# the immediate upstream is the Railway edge — set to "*" to trust it,
# or list explicit IPs. Without this, admin-session IP-binding and
# rate-limiting keys will all collapse to the proxy edge IP.
# Required value on Railway:
TRUSTED_PROXY_HOSTS=*

# Optional: Telegram/Discord webhook for alerts
# ALERT_WEBHOOK_URL=https://api.telegram.org/bot<token>/sendMessage?chat_id=<id>
